# Cowork Business OS .gitignore

# === System Files ===
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# === Credentials & Secrets ===
.env
.env.*
*.pem
*.key
credentials.json
secrets.json
**/credentials/
**/secrets/

# === Claude Local Settings ===
.claude/settings.local.json
.claude/credentials.json
.claude/*.local.md

# === State Backups ===
.claude/state.backups/

# === IDE/Editor ===
.vscode/settings.json
.idea/
*.sublime-*

# === Logs ===
*.log
logs/

# === Node (if used) ===
node_modules/

# === Python (if used) ===
__pycache__/
*.pyc
.venv/
venv/

# === Optional: heavy content types ===
# Uncomment if you store large files in cloud storage (Google Drive, Dropbox, etc.)
# rather than in the repo. Recommended for workspaces that sync across devices via git.
#
# *.docx
# *.doc
# *.xlsx
# *.xls
# *.pptx
# *.ppt
# *.pdf
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.mp3
# *.mp4
# *.mov
# *.zip
# *.csv
